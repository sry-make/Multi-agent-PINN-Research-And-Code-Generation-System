# PINN Agent V2 示例环境变量
#
# 用法:
#   cp .env.example .env
#   然后按需填写 API Key / 模型名

# ─────────────────────────────────────────────
# LLM Provider
# ─────────────────────────────────────────────
# 可选: ollama / qwen
PINN_AGENT_LLM_PROVIDER=ollama

# ─────────────────────────────────────────────
# 本地 Ollama
# ─────────────────────────────────────────────
PINN_AGENT_OLLAMA_BASE_URL=http://localhost:11434/v1
PINN_AGENT_OLLAMA_API_KEY=ollama-local
PINN_AGENT_LOCAL_MODEL_RESEARCHER=pinn_qwen_expert
PINN_AGENT_LOCAL_MODEL_CODER=qwen2.5:7b
PINN_AGENT_LOCAL_MODEL_EXAMINER=qwen2.5:7b
PINN_AGENT_LOCAL_MODEL_ROUTER=qwen2.5:7b

# ─────────────────────────────────────────────
# Qwen / DashScope OpenAI-Compatible API
# ─────────────────────────────────────────────
# 国内百炼:
# PINN_AGENT_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 国际站:
# PINN_AGENT_QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
PINN_AGENT_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PINN_AGENT_QWEN_API_KEY=
PINN_AGENT_QWEN_MODEL_RESEARCHER=qwen-plus
PINN_AGENT_QWEN_MODEL_CODER=qwen3-coder-plus
PINN_AGENT_QWEN_MODEL_EXAMINER=qwen-plus
PINN_AGENT_QWEN_MODEL_ROUTER=qwen-plus

# ─────────────────────────────────────────────
# Examiner 审查输入上限
# ─────────────────────────────────────────────
PINN_AGENT_EXAMINER_REPORT_CHARS=4000
PINN_AGENT_EXAMINER_CODE_CHARS=12000
PINN_AGENT_EXAMINER_STDIO_CHARS=1200
PINN_AGENT_EXAMINER_LLM_TIMEOUT_SEC=25
PINN_AGENT_EXAMINER_DEEP_CODE_REVIEW_ON_SUCCESS=false

# ─────────────────────────────────────────────
# Eval / LLM-as-Judge
# ─────────────────────────────────────────────
# auto: mock 评测走 heuristic judge，live 评测走真实 LLM judge
PINN_AGENT_EVAL_ENABLE_JUDGE=true
PINN_AGENT_EVAL_JUDGE_MODE=auto
PINN_AGENT_EVAL_JUDGE_MODEL=qwen-plus
PINN_AGENT_EVAL_JUDGE_TIMEOUT_SEC=20
PINN_AGENT_EVAL_JUDGE_MAX_TOKENS=800
PINN_AGENT_EVAL_JUDGE_PASS_THRESHOLD=75
PINN_AGENT_EVAL_JUDGE_WEIGHT=0.30
